# ── BankGen Platform — Variables d'environnement ──────────────────────────
# Copier ce fichier en .env et remplir vos valeurs Snowflake
# Ne jamais committer .env dans Git !

# ── Snowflake ──────────────────────────────────────────────────────────────
# Format account : orgname-accountname  (ex: myorg-myaccount)
# Visible dans Snowflake : Admin > Accounts > Copy Account Identifier
SF_ACCOUNT=orgname-accountname
SF_USER=your_username
SF_PASSWORD=your_password
SF_WAREHOUSE=COMPUTE_WH
SF_DATABASE=BANKGEN_DB
SF_SCHEMA=BANKING
SF_ROLE=SYSADMIN
